{
  "name": "wh40k-mfm-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Scrapes the Warhammer 40,000 Munitorum Field Manual into versioned YAML and tracks points changes over time.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "scrape": "tsx src/cli.ts",
    "refresh-fixtures": "tsx scripts/refresh-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "playwright": "^1.61.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.10.5",
    "lefthook": "^1.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
