{
  "name": "wh40k-mfm-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Scrapes the Warhammer 40,000 Munitorum Field Manual into versioned YAML and tracks points changes over time.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "scrape": "tsx src/cli.ts",
    "refresh-fixtures": "tsx scripts/refresh-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "playwright": "^1.61.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "lefthook": "^2.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
